# Copy this file to .env and fill in your values.
# .env is gitignored and loaded automatically by `yarn start`.
# In CI/CD and production, set these as real environment variables instead.

# ------------------------------------------------------------------
# Azure Entra ID — required for Microsoft sign-in
# See docs/azure-auth-setup.md for how to obtain these values.
# ------------------------------------------------------------------

# App Registration → Overview → Application (client) ID
AZURE_CLIENT_ID=

# App Registration → Overview → Directory (tenant) ID
AZURE_TENANT_ID=

# Option A — Client secret (App Registration → Certificates & secrets)
AZURE_CLIENT_SECRET=

# Option B — Certificate (comment out AZURE_CLIENT_SECRET and use this instead)
# AZURE_CLIENT_CERTIFICATE_PATH=/absolute/path/to/backstage-auth.pem

# ------------------------------------------------------------------
# GitHub integration — required for catalog / scaffolder GitHub actions
# https://backstage.io/docs/integrations/github/locations#configuration
# ------------------------------------------------------------------
GITHUB_TOKEN=
